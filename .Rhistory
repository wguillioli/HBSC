# -------------------------------------------------------------
# derivar new features
# -------------------------------------------------------------
# calcular Edad mama
d <- d %>%
mutate(EdadMama = as.period(interval(f_nac_madre, f_visita), unit = "years")) %>%
mutate(EdadMama = EdadMama %/% years(1)) %>%
mutate(EdadMamaBin = case_when(EdadMama < 18 ~ "<18",
EdadMama <= 35 ~ "18-35",
EdadMama > 35 ~ ">35",
TRUE ~ "-1"
)
) %>%
mutate(EdadMamaBin = factor(EdadMamaBin,
levels = c("<18", "18-35", ">35"),
ordered = TRUE))
# hora para el primer tamizaje mano desde hora nacimiento y bin c 6 hrs
d <- d %>%
mutate(hora_ox_manoExact = ymd_hms(paste(f_visita, hora_ox_mano))) %>%
mutate(HorasToOxMano1 = difftime(hora_ox_manoExact, f_nac_bebe, units = "hours")) %>%
mutate(HorasToOxMano1 = as.integer(HorasToOxMano1)) %>%
mutate(HorasToOxMano1Trimmed = case_when(HorasToOxMano1 < 18 ~ 18, #cap at p1 and p99
HorasToOxMano1 > 60 ~ 60,
TRUE ~ HorasToOxMano1),
HorasToOxMano1Bin =
case_when(HorasToOxMano1 <= 12 ~ "12 and below",
HorasToOxMano1 <= 18 ~ "13-18",
HorasToOxMano1 <= 24 ~ "18-24",
HorasToOxMano1 <= 30 ~ "24-30",
HorasToOxMano1 <= 36 ~ "30-36",
HorasToOxMano1 <= 42 ~ "36-42",
HorasToOxMano1 <= 48 ~ "42-48",
HorasToOxMano1 <= 54 ~ "48-54",
HorasToOxMano1 <= 60 ~ "54-60",
HorasToOxMano1 > 60 ~ "61+",
TRUE ~ "-1"
)
)
# hora para el primer tamizaje pie desde hora nacimiento y bin c 6 hrs
d <- d %>%
mutate(hora_ox_pieExact = ymd_hms(paste(f_visita, hora_ox_pie))) %>%
mutate(HorasToOxPie1 = difftime(hora_ox_pieExact, f_nac_bebe, units = "hours")) %>%
mutate(HorasToOxPie1 = as.integer(HorasToOxPie1)) %>%
mutate(HorasToOxPie1Trimmed = case_when(HorasToOxPie1 < 18 ~ 18, #cap at p1 and p99
HorasToOxPie1 > 60 ~ 60,
TRUE ~ HorasToOxPie1))
# -------------------------------------------------------------
# univariate demograficos de los participantes
# -------------------------------------------------------------
# keep only los uqe si participarpn
p <- d %>%
filter(madre_particip == 1)
cat("N POR LUGAR")
table(p$lugar, useNA = "always")
# Edad de la madre
cat("Distribucion Edad de la Madre (Percentiles)")
get_percentiles(p$EdadMama)
cat("Distribucion Edad de la Madre (Agrupada por Edad)")
p %>%
group_by(lugar, EdadMamaBin) %>%
tally() %>%
pivot_wider(names_from = lugar, values_from = n) %>%
mutate(coatepeque_pct = coatepeque/sum(coatepeque)) %>%
mutate(coban_pct = coban/sum(coban))
ggplot(p, aes(x = EdadMama, fill = lugar)) +
geom_histogram(alpha = 0.5) +
theme_minimal() +
ggtitle("Distribucion Edad Mama por lugar")
# cantidad embarazos
cat("Numero Embarazos de la madre")
p %>%
group_by(lugar, cant_embarazo) %>%
tally() %>%
pivot_wider(names_from = lugar, values_from = n)
# cantidad abortos
cat("Numero Abortos de la madre")
p %>%
mutate(abortos = ifelse(is.na(cant_ab), 0, cant_ab)) %>%
group_by(lugar, abortos) %>%
tally() %>%
pivot_wider(names_from = lugar, values_from = n)
# nivel escolar
#1, Primaria | 2, Básico | 3, Diversificado | 4, Universitario | 5, Ninguna
cat("Nivel Escolar de la madre")
p %>%
mutate(escolaridad2 = case_when(
escolaridad == 1 ~ "Primaria",
escolaridad == 2 ~ "Basico",
escolaridad == 3 ~ "Diversificado",
escolaridad == 4 ~ "Universitario",
escolaridad == 5 ~ "Ninguna",
TRUE ~ "ERROR"
)) %>%
group_by(escolaridad2) %>%
tally()
# sexo del bebe
#1, Masculino | 2, Femenino
cat("Sexo del bebe")
p %>%
mutate(sexo_bebe2 = case_when(
sexo_bebe == 1 ~ "Hombre",
sexo_bebe == 2 ~ "Mujer",
TRUE ~ "ERROR"
)) %>%
group_by(sexo_bebe2) %>%
tally()
# etnia_bebe
#1, Ladino/Mestizo | 2, Indigena | 4, No sabe | 3, Otro
# p %>%
#   group_by(etnia_bebe___1) %>%
#   tally() #NO SIRVE!
# peso_bebe y oz
# juntar lbs con oz y change to lbs con decimal
cat("Distribucion variable peso bebe (lbs)")
summary(p$peso_bebe)
cat("Distribucion variable peso bebe (oz)")
summary(p$peso_onzas)
cat("Distribucion peso bebe (lbs y oz combinado")
p$peso_bebe2 <- p$peso_bebe + p$peso_onzas / 16
summary(p$peso_bebe2)
ggplot(p, aes(x = peso_bebe2, fill = lugar)) +
geom_histogram(alpha = 0.5) +
theme_minimal() +
ggtitle("Distribucion peso del bebe (lbs)")
